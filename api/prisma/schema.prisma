  updatedAt     DateTime  @updatedAt @map("updated_at")

  spender User   @relation(fields: [userIdSpender], references: [id])
  branch  Branch @relation(fields: [branchId], references: [id])

  @@map("expenses")
}

// ─── REKAM MEDIS ──────────────────────────────────────────────────────────────

// Kartu rekam medis permanen — 1 hewan = 1 kartu, dibuat otomatis saat hewan pertama kali daftar
model MedicalRecord {
  id                 BigInt    @id @default(autoincrement())
  patientId          BigInt    @unique @map("patient_id")
  bloodType          String?   @map("blood_type")
  allergies          String?
  chronicConditions  String?   @map("chronic_conditions")
  specialNotes       String?   @map("special_notes")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  patient Patient @relation(fields: [patientId], references: [id])

  @@map("medical_records")
}

// Berat badan — wajib dicatat setiap kunjungan (check-up)
model WeightRecord {
  id              BigInt   @id @default(autoincrement())
  patientId       BigInt   @map("patient_id")
  checkUpResultId BigInt   @unique @map("check_up_result_id")
  weightKg        Decimal  @map("weight_kg") @db.Decimal(6, 2)
  recordedAt      DateTime @map("recorded_at")
  userId          BigInt   @map("user_id")
  createdAt       DateTime @default(now()) @map("created_at")

  patient       Patient       @relation(fields: [patientId], references: [id])
  checkUpResult CheckUpResult @relation(fields: [checkUpResultId], references: [id])

  @@map("weight_records")
}

// Riwayat vaksinasi
model VaccinationRecord {
  id              BigInt    @id @default(autoincrement())
  patientId       BigInt    @map("patient_id")
  checkUpResultId BigInt?   @map("check_up_result_id")
  vaccineName     String    @map("vaccine_name")
  batchNumber     String?   @map("batch_number")
  administeredAt  DateTime  @map("administered_at")
  nextDueAt       DateTime? @map("next_due_at")
  notes           String?
  userId          BigInt    @map("user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  patient       Patient        @relation(fields: [patientId], references: [id])
  checkUpResult CheckUpResult? @relation(fields: [checkUpResultId], references: [id])

  @@map("vaccination_records")
}

// Riwayat obat cacing
model DewormingRecord {
  id              BigInt    @id @default(autoincrement())
  patientId       BigInt    @map("patient_id")
  checkUpResultId BigInt?   @map("check_up_result_id")
  medicationName  String    @map("medication_name")
  administeredAt  DateTime  @map("administered_at")
  nextDueAt       DateTime? @map("next_due_at")
  notes           String?
  userId          BigInt    @map("user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  patient       Patient        @relation(fields: [patientId], references: [id])
  checkUpResult CheckUpResult? @relation(fields: [checkUpResultId], references: [id])

  @@map("deworming_records")
}

// Riwayat tindakan besar (operasi, sterilisasi, dll)
model MajorProcedureRecord {
  id              BigInt    @id @default(autoincrement())
  patientId       BigInt    @map("patient_id")
  checkUpResultId BigInt?   @map("check_up_result_id")
  procedureName   String    @map("procedure_name")
  performedAt     DateTime  @map("performed_at")
  notes           String?
  userId          BigInt    @map("user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  patient       Patient        @relation(fields: [patientId], references: [id])
  checkUpResult CheckUpResult? @relation(fields: [checkUpResultId], references: [id])

  @@map("major_procedure_records")
}

// ── WhatsApp Notification Log ────────────────────────────────────────────────

enum WaLogStatus {
  pending
  sent
  failed
}

enum WaNotifType {
  queue_confirmation
  queue_called
  vaccination_reminder
  deworming_reminder
  payment_receipt
  inpatient_update
  custom
}

model WhatsappLog {
  id             BigInt      @id @default(autoincrement())
  recipientPhone String      @map("recipient_phone")
  recipientName  String?     @map("recipient_name")
  type           WaNotifType
  message        String      @db.Text
  status         WaLogStatus @default(pending)
  errorMessage   String?     @map("error_message")
  sentAt         DateTime?   @map("sent_at")
  patientId      BigInt?     @map("patient_id")
  registrationId BigInt?     @map("registration_id")
  branchId       BigInt      @map("branch_id")
  userId         BigInt      @map("user_id")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  patient      Patient?      @relation(fields: [patientId], references: [id])
  branch       Branch        @relation(fields: [branchId], references: [id])

  @@map("whatsapp_logs")
}

// ── Staff Notification (in-app notification center) ──────────────────────────
// Broadcast per cabang — semua staf di cabang yang sama melihat notifikasi yang
// sama, "dibaca" bersifat global per notifikasi (bukan per user) untuk v1 ini.

enum StaffNotificationType {
  low_stock
  new_booking
  queue_new
}

model StaffNotification {
  id         BigInt                @id @default(autoincrement())
  branchId   BigInt                @map("branch_id")
  type       StaffNotificationType
  title      String
  message    String
  entityType String?               @map("entity_type")
  entityId   String?               @map("entity_id")
  isRead     Boolean               @default(false) @map("is_read")
  createdAt  DateTime              @default(now()) @map("created_at")

  branch Branch @relation(fields: [branchId], references: [id])

  @@index([branchId, isRead])
  @@map("staff_notifications")
}

// ── Booking & Appointment ────────────────────────────────────────────────────

enum AppointmentStatus {
  pending
  confirmed
  declined
  rescheduled
  converted
  cancelled
}

model Appointment {
  id              BigInt            @id @default(autoincrement())
  // Caller identity (boleh tanpa login)
  ownerName       String            @map("owner_name")
  ownerPhone      String            @map("owner_phone")
  petName         String            @map("pet_name")
  petCategory     String?           @map("pet_category")
  // Link ke pasien yang sudah terdaftar (opsional)
  patientId       BigInt?           @map("patient_id")
  // Target
  doctorUserId    BigInt            @map("doctor_user_id")
  branchId        BigInt            @map("branch_id")
  appointmentDate DateTime          @map("appointment_date") @db.Date
  appointmentTime String            @map("appointment_time") // "09:00"
  complaint       String
  notes           String?
  status          AppointmentStatus @default(pending)
  declineReason   String?           @map("decline_reason")
  // Jika sudah di-convert ke antrian
  registrationId  BigInt?           @unique @map("registration_id")
  // Audit
  handledBy       BigInt?           @map("handled_by")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  patient      Patient?  @relation(fields: [patientId], references: [id])
  doctor       User      @relation("DoctorAppointments", fields: [doctorUserId], references: [id])
  branch       Branch    @relation(fields: [branchId], references: [id])

  @@map("appointments")
}

// ── Reminder Log ─────────────────────────────────────────────────────────────

enum ReminderType {
  vaccination
  deworming
}

enum ReminderStatus {
  pending
  sent
  failed
  skipped
}

model ReminderLog {
  id         BigInt         @id @default(autoincrement())
  type       ReminderType
  patientId  BigInt         @map("patient_id")
  recordId   BigInt         @map("record_id")   // VaccinationRecord.id or DewormingRecord.id
  dueDate    DateTime       @map("due_date")     @db.Date
  status     ReminderStatus @default(pending)
  channel    String         @default("whatsapp")
  sentAt     DateTime?      @map("sent_at")
  errorMsg   String?        @map("error_msg")
  createdAt  DateTime       @default(now()) @map("created_at")

  patient    Patient        @relation(fields: [patientId], references: [id])

  @@unique([type, recordId])   // satu record = satu reminder log per siklus
  @@map("reminder_logs")
}

// ── Owner OTP (untuk portal pemilik) ─────────────────────────────────────────

model OwnerOTP {
  id        BigInt   @id @default(autoincrement())
  ownerId   BigInt   @map("owner_id")
  otp       String   @db.VarChar(6)
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  owner     Owner    @relation(fields: [ownerId], references: [id])

  @@map("owner_otps")
}

// ── Grooming / Salon ─────────────────────────────────────────────────────────

enum GroomingStatus {
  waiting
  in_progress
  done
  cancelled
}

model GroomingPackage {
  id          BigInt   @id @default(autoincrement())
  packageName String   @map("package_name")
  description String?
  price       Decimal  @db.Decimal(15, 2)
  durationMin Int      @default(60) @map("duration_min")
  branchId    BigInt   @map("branch_id")
  isActive    Boolean  @default(true) @map("is_active")
  isDeleted   Boolean  @default(false) @map("is_deleted")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  branch   Branch           @relation(fields: [branchId], references: [id])
  sessions GroomingSession[]

  @@map("grooming_packages")
}

model GroomingSession {
  id          BigInt         @id @default(autoincrement())
  queueNumber Int            @map("queue_number")
  patientId   BigInt         @map("patient_id")
  groomerId   BigInt         @map("groomer_id")
  packageId   BigInt         @map("package_id")
  branchId    BigInt         @map("branch_id")
  status      GroomingStatus @default(waiting)
  scheduledAt DateTime?      @map("scheduled_at")
  startedAt   DateTime?      @map("started_at")
  completedAt DateTime?      @map("completed_at")
  notes       String?
  totalPrice  Decimal        @default(0) @map("total_price") @db.Decimal(15, 2)
  discount    Decimal        @default(0) @db.Decimal(15, 2)
  isPaid      Boolean        @default(false) @map("is_paid")
  userId      BigInt         @map("user_id")
  isDeleted   Boolean        @default(false) @map("is_deleted")
  deletedAt   DateTime?      @map("deleted_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  patient    Patient         @relation(fields: [patientId], references: [id])
  groomer    User            @relation("GroomerSessions", fields: [groomerId], references: [id])
  registrant User            @relation("GroomingRegistrant", fields: [userId], references: [id])
  package    GroomingPackage @relation(fields: [packageId], references: [id])
  branch     Branch          @relation(fields: [branchId], references: [id])

  @@map("grooming_sessions")
}

// ─── AUDIT TRAIL ─────────────────────────────────────────────────────────────

model AuditLog {
  id         BigInt   @id @default(autoincrement())
  tenantId   BigInt?  @map("tenant_id")
  userId     BigInt?  @map("user_id")
  username   String?
  action     String
  resource   String
  resourceId String?  @map("resource_id")
  details    Json?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([userId])
  @@index([resource, action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── F-28: Broadcast & CRM WhatsApp ─────────────────────────────────────────

enum BroadcastStatus {
  draft
  sending
  done
  failed
}

model BroadcastLog {
  id           BigInt          @id @default(autoincrement())
  tenantId     BigInt?         @map("tenant_id")
  branchId     BigInt          @map("branch_id")
  userId       BigInt          @map("user_id")
  title        String
  message      String          @db.Text
  segment      Json?
  status       BroadcastStatus @default(draft)
  totalTarget  Int             @default(0) @map("total_target")
  totalSent    Int             @default(0) @map("total_sent")
  totalFailed  Int             @default(0) @map("total_failed")
  scheduledAt  DateTime?       @map("scheduled_at")
  startedAt    DateTime?       @map("started_at")
  completedAt  DateTime?       @map("completed_at")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  branch     Branch              @relation(fields: [branchId], references: [id])
  user       User                @relation(fields: [userId], references: [id])
  recipients BroadcastRecipient[]

  @@index([tenantId])
  @@index([branchId])
  @@map("broadcast_logs")
}

model BroadcastRecipient {
  id           BigInt   @id @default(autoincrement())
  broadcastId  BigInt   @map("broadcast_id")
  ownerId      BigInt   @map("owner_id")
  phone        String
  status       String   @default("pending")
  sentAt       DateTime? @map("sent_at")
  errorMsg     String?   @map("error_msg")

  broadcast    BroadcastLog @relation(fields: [broadcastId], references: [id])
  owner        Owner        @relation(fields: [ownerId], references: [id])

  @@map("broadcast_recipients")
}

// ─── F-29: Loyalty Program ───────────────────────────────────────────────────

model LoyaltyConfig {
  id              BigInt   @id @default(autoincrement())
  tenantId        BigInt?  @map("tenant_id")
  branchId        BigInt   @unique @map("branch_id")
  pointsPerRupiah Decimal  @default(0.001) @map("points_per_rupiah") @db.Decimal(10, 6)
  silverThreshold Int      @default(500)  @map("silver_threshold")
  goldThreshold   Int      @default(2000) @map("gold_threshold")
  redeemRate      Decimal  @default(100) @map("redeem_rate") @db.Decimal(10, 2)
  isActive        Boolean  @default(true) @map("is_active")
  updatedAt       DateTime @updatedAt @map("updated_at")

  branch  Branch @relation(fields: [branchId], references: [id])

  @@map("loyalty_configs")
}

enum LoyaltyTxType {
  earn
  redeem
  bonus
  adjust
}

model LoyaltyPoint {
  id          BigInt        @id @default(autoincrement())
  ownerId     BigInt        @map("owner_id")
  branchId    BigInt        @map("branch_id")
  tenantId    BigInt?       @map("tenant_id")
  txType      LoyaltyTxType @map("tx_type")
  points      Int
  balance     Int
  description String?
  refId       String?       @map("ref_id")
  createdAt   DateTime      @default(now()) @map("created_at")

  owner   Owner  @relation(fields: [ownerId], references: [id])
  branch  Branch @relation(fields: [branchId], references: [id])

  @@index([ownerId])
  @@index([branchId])
  @@map("loyalty_points")
}

model LoyaltyMember {
  id          BigInt   @id @default(autoincrement())
  ownerId     BigInt   @map("owner_id")
  branchId    BigInt   @map("branch_id")
  tenantId    BigInt?  @map("tenant_id")
  totalPoints Int      @default(0) @map("total_points")
  tier        String   @default("basic")
  totalSpend  Decimal  @default(0) @map("total_spend") @db.Decimal(15, 2)
  joinedAt    DateTime @default(now()) @map("joined_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner   Owner  @relation(fields: [ownerId], references: [id])
  branch  Branch @relation(fields: [branchId], references: [id])

  @@unique([ownerId, branchId])
  @@map("loyalty_members")
}



// ─── F-30: Rating & Ulasan Pasca-Kunjungan ───────────────────────────────────

model ReviewRecord {
  id             BigInt    @id @default(autoincrement())
  registrationId BigInt    @unique @map("registration_id")
  patientId      BigInt    @map("patient_id")
  doctorId       BigInt    @map("doctor_id")
  branchId       BigInt    @map("branch_id")
  tenantId       BigInt?   @map("tenant_id")
  rating         Int?
  comment        String?
  isPublished    Boolean   @default(false) @map("is_published")
  surveyToken    String    @unique @map("survey_token")
  sentAt         DateTime? @map("sent_at")
  repliedAt      DateTime? @map("replied_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  registration Registration @relation(fields: [registrationId], references: [id])
  patient      Patient      @relation(fields: [patientId], references: [id])
  doctor       User         @relation("DoctorReviews", fields: [doctorId], references: [id])
  branch       Branch       @relation(fields: [branchId], references: [id])

  @@index([branchId])
  @@index([doctorId])
  @@index([rating])
  @@map("review_records")
}

// ─── F-31: Jadwal Dokter & Shift ─────────────────────────────────────────────

model DoctorSchedule {
  id          BigInt   @id @default(autoincrement())
  doctorId    BigInt   @map("doctor_id")
  branchId    BigInt   @map("branch_id")
  tenantId    BigInt?  @map("tenant_id")
  dayOfWeek   Int      @map("day_of_week")   // 0=Sun 1=Mon ... 6=Sat
  shiftStart  String   @map("shift_start")   // "08:00"
  shiftEnd    String   @map("shift_end")     // "16:00"
  maxPatients Int      @default(20) @map("max_patients")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  doctor  User   @relation("DoctorSchedules", fields: [doctorId], references: [id])
  branch  Branch @relation(fields: [branchId], references: [id])

  @@unique([doctorId, branchId, dayOfWeek])
  @@map("doctor_schedules")
}

enum LeaveStatus {
  pending
  approved
  declined
}

model DoctorLeave {
  id          BigInt      @id @default(autoincrement())
  doctorId    BigInt      @map("doctor_id")
  branchId    BigInt      @map("branch_id")
  tenantId    BigInt?     @map("tenant_id")
  leaveDate   DateTime    @map("leave_date")
  reason      String?
  status      LeaveStatus @default(pending)
  approvedBy  BigInt?     @map("approved_by")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  doctor    User    @relation("DoctorLeaves", fields: [doctorId], references: [id])
  approver  User?   @relation("LeaveApprovals", fields: [approvedBy], references: [id])
  branch    Branch  @relation(fields: [branchId], references: [id])

  @@index([doctorId])
  @@index([leaveDate])
  @@map("doctor_leaves")
}

// ─── F-32: Pet Hotel / Penginapan Hewan ──────────────────────────────────────

enum HotelRoomType {
  vip
  reguler
  isolasi
}

enum HotelBookingStatus {
  pending
  checkedin
  checkedout
  cancelled
}

model HotelRoom {
  id            BigInt       @id @default(autoincrement())
  branchId      BigInt       @map("branch_id")
  tenantId      BigInt?      @map("tenant_id")
  roomName      String       @map("room_name")
  roomType      HotelRoomType @default(reguler) @map("room_type")
  capacity      Int          @default(1)
  pricePerNight Decimal      @map("price_per_night") @db.Decimal(15, 2)
  description   String?
  isActive      Boolean      @default(true) @map("is_active")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  branch   Branch         @relation(fields: [branchId], references: [id])
  bookings HotelBooking[]

  @@index([branchId])
  @@map("hotel_rooms")
}

model HotelBooking {
  id           BigInt             @id @default(autoincrement())
  roomId       BigInt             @map("room_id")
  patientId    BigInt             @map("patient_id")
  ownerId      BigInt             @map("owner_id")
  branchId     BigInt             @map("branch_id")
  tenantId     BigInt?            @map("tenant_id")
  checkIn      DateTime           @map("check_in")
  checkOut     DateTime           @map("check_out")
  totalNights  Int                @default(1) @map("total_nights")
  totalPrice   Decimal            @default(0) @map("total_price") @db.Decimal(15, 2)
  specialNeeds String?            @map("special_needs")
  status       HotelBookingStatus @default(pending)
  isPaid       Boolean            @default(false) @map("is_paid")
  notes        String?
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  room     HotelRoom      @relation(fields: [roomId], references: [id])
  patient  Patient        @relation(fields: [patientId], references: [id])
  owner    Owner          @relation(fields: [ownerId], references: [id])
  branch   Branch         @relation(fields: [branchId], references: [id])
  careLogs HotelCareLog[]

  @@index([branchId])
  @@index([checkIn, checkOut])
  @@map("hotel_bookings")
}

model HotelCareLog {
  id            BigInt   @id @default(autoincrement())
  bookingId     BigInt   @map("booking_id")
  staffId       BigInt   @map("staff_id")
  logDate       DateTime @map("log_date")
  mealNote      String?  @map("meal_note")
  drinkNote     String?  @map("drink_note")
  activityNote  String?  @map("activity_note")
  conditionNote String?  @map("condition_note")
  photoUrl      String?  @map("photo_url")
  sentToOwner   Boolean  @default(false) @map("sent_to_owner")
  createdAt     DateTime @default(now()) @map("created_at")

  booking HotelBooking @relation(fields: [bookingId], references: [id])
  staff   User         @relation(fields: [staffId], references: [id])

  @@index([bookingId])
  @@map("hotel_care_logs")
}

// ─── F-33: Telemedicine / Konsultasi Online ───────────────────────────────────

enum TelemedStatus {
  pending
  confirmed
  ongoing
  done
  cancelled
}

model TelemedSession {
  id          BigInt        @id @default(autoincrement())
  patientId   BigInt        @map("patient_id")
  doctorId    BigInt        @map("doctor_id")
  ownerId     BigInt        @map("owner_id")
  branchId    BigInt        @map("branch_id")
  tenantId    BigInt?       @map("tenant_id")
  status      TelemedStatus @default(pending)
  channel     String        @default("chat")
  scheduledAt DateTime?     @map("scheduled_at")
  startedAt   DateTime?     @map("started_at")
  endedAt     DateTime?     @map("ended_at")
  complaint   String?
  doctorNotes String?       @map("doctor_notes")
  ePrescription String?     @map("e_prescription")
  fee         Decimal       @default(0) @db.Decimal(15, 2)
  isPaid      Boolean       @default(false) @map("is_paid")
  rating      Int?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  patient Patient @relation(fields: [patientId], references: [id])
  doctor  User    @relation("DoctorTelemeds", fields: [doctorId], references: [id])
  owner   Owner   @relation(fields: [ownerId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])

  @@index([branchId])
  @@index([doctorId])
  @@map("telemed_sessions")
}

// ─── F-34: Manajemen Lab & Hasil Pemeriksaan ─────────────────────────────────

enum LabStatus {
  pending
  processing
  ready
}

model LabRequest {
  id             BigInt    @id @default(autoincrement())
  branchId       BigInt    @map("branch_id")
  tenantId       BigInt?   @map("tenant_id")
  patientId      BigInt    @map("patient_id")
  requestedById  BigInt    @map("requested_by_id")
  testType       String    @map("test_type")
  notes          String?
  status         LabStatus @default(pending)
  priority       String    @default("normal")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  branch      Branch     @relation(fields: [branchId], references: [id])
  patient     Patient    @relation(fields: [patientId], references: [id])
  requestedBy User       @relation("DoctorLabRequests", fields: [requestedById], references: [id])
  result      LabResult?

  @@index([patientId])
  @@index([branchId])
  @@map("lab_requests")
}

model LabResult {
  id              BigInt    @id @default(autoincrement())
  requestId       BigInt    @unique @map("request_id")
  templateType    String?   @map("template_type")
  resultData      Json?     @map("result_data")
  resultFile      String?   @map("result_file")
  interpretation  String?
  isReady         Boolean   @default(false) @map("is_ready")
  readyAt         DateTime? @map("ready_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  request LabRequest @relation(fields: [requestId], references: [id])

  @@map("lab_results")
}

// ─── F-36: AI Symptom Checker ────────────────────────────────────────────────

enum UrgencyLevel {
  segera
  dalam_24_jam
  bisa_tunggu
  tidak_perlu
}

model AiSymptomLog {
  id              BigInt       @id @default(autoincrement())
  branchId        BigInt?      @map("branch_id")
  tenantId        BigInt?      @map("tenant_id")
  petName         String?      @map("pet_name")
  species         String?
  age             Int?
  inputSymptoms   String       @map("input_symptoms")
  aiResponse      String       @map("ai_response")
  urgencyLevel    UrgencyLevel @map("urgency_level")
  bookingCreated  Boolean      @default(false) @map("booking_created")
  createdAt       DateTime     @default(now()) @map("created_at")

  @@index([branchId])
  @@index([urgencyLevel])
  @@map("ai_symptom_logs")
}

// ─── F-37: Drug Interaction & Kalkulator Dosis ───────────────────────────────

model DrugDatabase {
  id                 BigInt    @id @default(autoincrement())
  drugName           String    @unique @map("drug_name")
  genericName        String?   @map("generic_name")
  category           String    @default("umum")
  species            String    @default("all")
  dosagePerKgMin     Decimal?  @map("dosage_per_kg_min") @db.Decimal(10, 4)
  dosagePerKgMax     Decimal?  @map("dosage_per_kg_max") @db.Decimal(10, 4)
  unit               String    @default("mg")
  frequency          String?
  contraindications  String?
  sideEffects        String?   @map("side_effects")
  isActive           Boolean   @default(true) @map("is_active")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  interactionsAsA DrugInteraction[] @relation("DrugA")
  interactionsAsB DrugInteraction[] @relation("DrugB")

  @@map("drug_database")
}

model DrugInteraction {
  id          BigInt @id @default(autoincrement())
  drugAId     BigInt @map("drug_a_id")
  drugBId     BigInt @map("drug_b_id")
  severity    String // warning / danger
  description String
  createdAt   DateTime @default(now()) @map("created_at")

  drugA DrugDatabase @relation("DrugA", fields: [drugAId], references: [id])
  drugB DrugDatabase @relation("DrugB", fields: [drugBId], references: [id])

  @@unique([drugAId, drugBId])
  @@map("drug_interactions")
}

// ─── F-40: Google Calendar Sync ──────────────────────────────────────────────

model DoctorCalendarSync {
  id                  BigInt    @id @default(autoincrement())
  doctorId            BigInt    @unique @map("doctor_id")
  googleAccessToken   String?   @map("google_access_token")
  googleRefreshToken  String?   @map("google_refresh_token")
  googleEmail         String?   @map("google_email")
  syncEnabled         Boolean   @default(false) @map("sync_enabled")
  lastSyncAt          DateTime? @map("last_sync_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  doctor User @relation("CalendarSync", fields: [doctorId], references: [id])

  @@map("doctor_calendar_syncs")
}

// ─── F-42: Integrasi Marketplace ─────────────────────────────────────────────

model MarketplaceIntegration {
  id           BigInt    @id @default(autoincrement())
  branchId     BigInt    @map("branch_id")
  tenantId     BigInt?   @map("tenant_id")
  platform     String    // tokopedia / shopee
  shopId       String?   @map("shop_id")
  shopName     String?   @map("shop_name")
  accessToken  String?   @map("access_token")
  syncEnabled  Boolean   @default(false) @map("sync_enabled")
  lastSyncAt   DateTime? @map("last_sync_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  branch Branch              @relation(fields: [branchId], references: [id])
  orders MarketplaceOrder[]

  @@unique([branchId, platform])
  @@map("marketplace_integrations")
}

model MarketplaceOrder {
  id              BigInt    @id @default(autoincrement())
  integrationId   BigInt    @map("integration_id")
  orderId         String    @map("order_id")
  platform        String
  customerName    String    @map("customer_name")
  items           Json
  totalAmount     Decimal   @map("total_amount") @db.Decimal(15, 2)
  status          String    @default("pending")
  orderDate       DateTime  @map("order_date")
  createdAt       DateTime  @default(now()) @map("created_at")

  integration MarketplaceIntegration @relation(fields: [integrationId], references: [id])

  @@index([integrationId])
  @@map("marketplace_orders")
}
