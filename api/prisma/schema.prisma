generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum UserRole {
  superadmin
  admin
  dokter
  resepsionis
  kasir
  karyawan
}

enum TenantStatus {
  trial
  active
  suspended
  cancelled
}

enum PlanCode {
  free
  starter
  pro
  enterprise
}

// ─── TENANT / MULTI-TENANCY ──────────────────────────────────────────────────

model Tenant {
  id          BigInt       @id @default(autoincrement())
  name        String
  slug        String       @unique
  email       String       @unique
  phoneNumber String?      @map("phone_number")
  address     String?
  logoUrl     String?      @map("logo_url")
  status      TenantStatus @default(trial)
  trialEndsAt DateTime?    @map("trial_ends_at")
  isDeleted   Boolean      @default(false) @map("is_deleted")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  branches     Branch[]
  users        User[]
  subscription TenantSubscription?
  invoices     BillingInvoice[]

  @@map("tenants")
}

model SubscriptionPlan {
  id           BigInt   @id @default(autoincrement())
  code         PlanCode @unique
  name         String
  priceMonthly Decimal  @default(0) @map("price_monthly") @db.Decimal(15, 2)
  priceYearly  Decimal  @default(0) @map("price_yearly") @db.Decimal(15, 2)
  maxBranches  Int      @default(1) @map("max_branches")
  maxUsers     Int      @default(5) @map("max_users")
  maxPatients  Int      @default(500) @map("max_patients")
  features     Json     @default("{}")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  subscriptions TenantSubscription[]
  invoices      BillingInvoice[]

  @@map("subscription_plans")
}

enum BillingInvoiceStatus {
  pending
  paid
  failed
  expired
  cancelled
}

model BillingInvoice {
  id              BigInt               @id @default(autoincrement())
  tenantId        BigInt               @map("tenant_id")
  planId          BigInt               @map("plan_id")
  cycle           String               @default("monthly")
  orderId         String               @unique @map("order_id")
  amount          Decimal              @db.Decimal(15, 2)
  status          BillingInvoiceStatus @default(pending)
  snapToken       String?              @map("snap_token")
  paymentType     String?              @map("payment_type")
  paidAt          DateTime?            @map("paid_at")
  rawNotification Json?                @map("raw_notification")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  tenant Tenant           @relation(fields: [tenantId], references: [id])
  plan   SubscriptionPlan @relation(fields: [planId], references: [id])

  @@map("billing_invoices")
}

model TenantSubscription {
  id          BigInt    @id @default(autoincrement())
  tenantId    BigInt    @unique @map("tenant_id")
  planId      BigInt    @map("plan_id")
  cycle       String    @default("monthly")
  status      String    @default("trial")
  startedAt   DateTime  @default(now()) @map("started_at")
  expiresAt   DateTime? @map("expires_at")
  cancelledAt DateTime? @map("cancelled_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  tenant Tenant           @relation(fields: [tenantId], references: [id])
  plan   SubscriptionPlan @relation(fields: [planId], references: [id])

  @@map("tenant_subscriptions")
}

enum AcceptanceStatus {
  pending
  accepted
  declined
  cancelled
}

enum StockMovementStatus {
  masuk
  keluar
  adjustment
}

// ─── MASTER DATA ─────────────────────────────────────────────────────────────

model Branch {
  id                 BigInt    @id @default(autoincrement())
  tenantId           BigInt?   @map("tenant_id")
  branchCode         String    @unique @map("branch_code")
  branchName         String    @map("branch_name")
  address            String?
  phoneNumber        String?   @map("phone_number")
  email              String?
  operatingHours     String?   @map("operating_hours")
  paymentInstruction String?   @map("payment_instruction")
  isActive           Boolean   @default(true) @map("is_active")
  isDeleted          Boolean   @default(false) @map("is_deleted")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  tenant                  Tenant?  @relation(fields: [tenantId], references: [id])
  users                   User[]
  owners                  Owner[]
  patients                Patient[]
  categoryItems           CategoryItem[]
  unitItems               UnitItem[]
  listOfItems             ListOfItem[]
  listOfItemPetShops      ListOfItemPetShop[]
  serviceCategories       ServiceCategory[]
  listOfServices          ListOfService[]
  medicineGroups          MedicineGroup[]
  masterPaymentPetshops   MasterPaymentPetshop[]
  registrations           Registration[]
  inPatients              InPatient[]
  expenses                Expense[]
  payrolls                Payroll[]
  waLogs                  WhatsappLog[]
  appointments            Appointment[]
  groomingPackages        GroomingPackage[]
  groomingSessions        GroomingSession[]
  broadcastLogs           BroadcastLog[]
  loyaltyConfig           LoyaltyConfig?
  loyaltyPoints           LoyaltyPoint[]
  loyaltyMembers          LoyaltyMember[]
  reviewRecords           ReviewRecord[]
  doctorSchedules         DoctorSchedule[]
  doctorLeaves            DoctorLeave[]
  hotelRooms              HotelRoom[]
  hotelBookings           HotelBooking[]
  telemedSessions         TelemedSession[]
  labRequests             LabRequest[]
  marketplaceIntegrations MarketplaceIntegration[]
  staffNotifications      StaffNotification[]

  @@map("branches")
}

model User {
  id              BigInt    @id @default(autoincrement())
  staffingNumber  String?   @unique @map("staffing_number")
  username        String    @unique
  fullname        String
  email           String?
  password        String
  gender          String?
  religion        String?
  birthPlace      String?   @map("birth_place")
  birthdate       DateTime?
  bloodGroup      String?   @map("blood_group")
  idCardNumber    String?   @map("id_card_number")
  phoneNumber     String?   @map("phone_number")
  homeNumber      String?   @map("home_number")
  address         String?
  imageProfile    String?   @map("image_profile")
  role            UserRole
  status          Boolean   @default(true)
  branchId        BigInt    @map("branch_id")
  tenantId        BigInt?   @map("tenant_id")
  ptkpStatus      String    @default("TK0") @map("ptkp_status")
  npwp            String?
  isDeleted       Boolean   @default(false) @map("is_deleted")
  deletedAt       DateTime? @map("deleted_at")
  deletedBy       String?   @map("deleted_by")
  createdBy       String?   @map("created_by")
  updatedBy       String?   @map("updated_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  branch              Branch              @relation(fields: [branchId], references: [id])
  tenant              Tenant?             @relation(fields: [tenantId], references: [id])
  refreshTokens       RefreshToken[]
  registrations       Registration[]      @relation("DoctorRegistrations")
  registrationsBy     Registration[]      @relation("StaffRegistrations")
  acceptances         DoctorAcceptance[]
  checkUpResults      CheckUpResult[]
  payrolls            Payroll[]           @relation("EmployeePayrolls")
  payrollsCreated     Payroll[]           @relation("CreatedByPayrolls")
  expenses            Expense[]
  paymentsPetshop     PaymentPetshop[]
  payments            ListOfPayment[]
  appointments        Appointment[]    @relation("DoctorAppointments")
  groomingSessions      GroomingSession[] @relation("GroomerSessions")
  groomingRegistrations GroomingSession[] @relation("GroomingRegistrant")
  broadcastLogs         BroadcastLog[]
  reviewsAsDoctor       ReviewRecord[]    @relation("DoctorReviews")
  doctorSchedules       DoctorSchedule[]  @relation("DoctorSchedules")
  doctorLeaves          DoctorLeave[]     @relation("DoctorLeaves")
  leaveApprovals        DoctorLeave[]     @relation("LeaveApprovals")
  telemedSessions       TelemedSession[]  @relation("DoctorTelemeds")
  labRequests           LabRequest[]      @relation("DoctorLabRequests")
  calendarSync          DoctorCalendarSync? @relation("CalendarSync")
  hotelCareLogs         HotelCareLog[]

  @@map("users")
}

model RefreshToken {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("refresh_tokens")
}

// ─── OWNER & PATIENT ──────────────────────────────────────────────────────────

model Owner {
  id          BigInt    @id @default(autoincrement())
  ownerName   String    @map("owner_name")
  address     String?
  phoneNumber String?   @map("phone_number")
  branchId    BigInt    @map("branch_id")
  isDeleted   Boolean   @default(false) @map("is_deleted")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  branch   Branch      @relation(fields: [branchId], references: [id])
  patients Patient[]
  otps     OwnerOTP[]
  broadcastRecipients BroadcastRecipient[]
  loyaltyPoints       LoyaltyPoint[]
  loyaltyMembers      LoyaltyMember[]
  hotelBookings       HotelBooking[]
  telemedSessions     TelemedSession[]

  @@map("owners")
}

model Patient {
  id           BigInt    @id @default(autoincrement())
  idMember     String    @unique @map("id_member")
  petCategory  String    @map("pet_category")
  petName      String    @map("pet_name")
  petGender    String?   @map("pet_gender")
  petYearAge   Int?      @map("pet_year_age")
  petMonthAge  Int?      @map("pet_month_age")
  ownerId      BigInt    @map("owner_id")
  branchId     BigInt    @map("branch_id")
  userId       BigInt    @map("user_id")
  isDeleted    Boolean   @default(false) @map("is_deleted")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  owner         Owner          @relation(fields: [ownerId], references: [id])
  branch        Branch         @relation(fields: [branchId], references: [id])
  registrations Registration[]
  inPatients    InPatient[]
  medicalRecord MedicalRecord?
  weightRecords WeightRecord[]
  vaccinations  VaccinationRecord[]
  dewormings    DewormingRecord[]
  procedures    MajorProcedureRecord[]
  waLogs           WhatsappLog[]
  appointments     Appointment[]
  reminderLogs     ReminderLog[]
  groomingSessions GroomingSession[]
  reviews          ReviewRecord[]
  hotelBookings    HotelBooking[]
  telemedSessions  TelemedSession[]
  labRequests      LabRequest[]

  @@map("patients")
}

// ─── REGISTRATION & ACCEPTANCE ───────────────────────────────────────────────

model Registration {
  id               BigInt    @id @default(autoincrement())
  idNumber         String    @unique @map("id_number")
  patientId        BigInt    @map("patient_id")
  doctorUserId     BigInt    @map("doctor_user_id")
  userId           BigInt    @map("user_id")
  branchId         BigInt    @map("branch_id")
  complaint        String
  registrant       String
  visitType        String    @default("baru") @map("visit_type")
  queueNumber      Int?      @map("queue_number")
  isPriority       Boolean   @default(false) @map("is_priority")
  cancelReason     String?   @map("cancel_reason")
  acceptanceStatus AcceptanceStatus @default(pending) @map("acceptance_status")
  isHideFromDropDown Boolean  @default(false) @map("is_hide_from_drop_down")
  isDeleted        Boolean   @default(false) @map("is_deleted")
  deletedAt        DateTime? @map("deleted_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  patient         Patient          @relation(fields: [patientId], references: [id])
  doctor          User             @relation("DoctorRegistrations", fields: [doctorUserId], references: [id])
  createdBy       User             @relation("StaffRegistrations", fields: [userId], references: [id])
  branch          Branch           @relation(fields: [branchId], references: [id])
  doctorAcceptance DoctorAcceptance?
  checkUpResult   CheckUpResult?
  review          ReviewRecord?

  @@map("registrations")
}

model DoctorAcceptance {
  id             BigInt   @id @default(autoincrement())
  registrationId BigInt   @unique @map("registration_id")
  userId         BigInt   @map("user_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  registration Registration @relation(fields: [registrationId], references: [id])
  doctor       User         @relation(fields: [userId], references: [id])

  @@map("doctor_acceptances")
}

// ─── INPATIENT ────────────────────────────────────────────────────────────────

model InPatient {
  id               BigInt    @id @default(autoincrement())
  idNumber         String    @unique @map("id_number")
  patientId        BigInt    @map("patient_id")
  doctorUserId     BigInt    @map("doctor_user_id")
  branchId         BigInt    @map("branch_id")
  complaint        String
  registrant       String
  estimateDay      Int?      @map("estimate_day")
  realityDay       Int?      @map("reality_day")
  acceptanceStatus AcceptanceStatus @default(pending) @map("acceptance_status")
  isDeleted        Boolean   @default(false) @map("is_deleted")
  deletedAt        DateTime? @map("deleted_at")
  userId           BigInt    @map("user_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  patient Patient @relation(fields: [patientId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])

  @@map("in_patients")
}

// ─── INVENTORY — ITEMS ───────────────────────────────────────────────────────

model CategoryItem {
  id           BigInt    @id @default(autoincrement())
  categoryName String    @map("category_name")
  branchId     BigInt    @map("branch_id")
  isDeleted    Boolean   @default(false) @map("is_deleted")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  branch        Branch         @relation(fields: [branchId], references: [id])
  listOfItems   ListOfItem[]

  @@map("category_items")
}

model UnitItem {
  id        BigInt    @id @default(autoincrement())
  unitName  String    @map("unit_name")
  branchId  BigInt    @map("branch_id")
  isDeleted Boolean   @default(false) @map("is_deleted")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  branch      Branch       @relation(fields: [branchId], references: [id])
  listOfItems ListOfItem[]

  @@map("unit_items")
}

model ListOfItem {
  id             BigInt    @id @default(autoincrement())
  itemName       String    @map("item_name")
  description    String?
  totalItem      Decimal   @default(0) @map("total_item") @db.Decimal(10, 2)
  limitItem      Decimal?  @map("limit_item") @db.Decimal(10, 2)
  expiredDate    DateTime? @map("expired_date")
  isActive       Boolean   @default(true) @map("is_active")
  unitItemId     BigInt    @map("unit_item_id")
  categoryItemId BigInt    @map("category_item_id")
  branchId       BigInt    @map("branch_id")
  isDeleted      Boolean   @default(false) @map("is_deleted")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  barcodeId          String?   @unique @map("barcode_id")

  unitItem           UnitItem            @relation(fields: [unitItemId], references: [id])
  categoryItem       CategoryItem        @relation(fields: [categoryItemId], references: [id])
  branch             Branch              @relation(fields: [branchId], references: [id])
  priceItems         PriceItem[]
  stockMovements     StockMovement[]

  @@map("list_of_items")
}

model PriceItem {
  id           BigInt    @id @default(autoincrement())
  listOfItemId BigInt    @map("list_of_items_id")
  sellingPrice Decimal   @map("selling_price") @db.Decimal(15, 2)
  capitalPrice Decimal   @map("capital_price") @db.Decimal(15, 2)
  doctorFee    Decimal   @default(0) @map("doctor_fee") @db.Decimal(15, 2)
  petshopFee   Decimal   @default(0) @map("petshop_fee") @db.Decimal(15, 2)
  isDeleted    Boolean   @default(false) @map("is_deleted")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  listOfItem         ListOfItem          @relation(fields: [listOfItemId], references: [id])
  detailItemPatients DetailItemPatient[]

  @@map("price_items")
}

model StockMovement {
  id           BigInt              @id @default(autoincrement())
  listOfItemId BigInt              @map("list_of_item_id")
  quantity     Decimal             @db.Decimal(10, 2)
  status       StockMovementStatus
  notes        String?
  userId       BigInt              @map("user_id")
  isDeleted    Boolean             @default(false) @map("is_deleted")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  listOfItem ListOfItem @relation(fields: [listOfItemId], references: [id])

  @@map("stock_movements")
}

// ─── INVENTORY — PETSHOP ITEMS ────────────────────────────────────────────────

model ListOfItemPetShop {
  id             BigInt    @id @default(autoincrement())
  itemName       String    @map("item_name")
  totalItem      Decimal   @default(0) @map("total_item") @db.Decimal(10, 2)
  limitItem      Decimal?  @map("limit_item") @db.Decimal(10, 2)
  expiredDate    DateTime? @map("expired_date")
  unitItemId     BigInt    @map("unit_item_id")
  categoryItemId BigInt    @map("category_item_id")
  branchId       BigInt    @map("branch_id")
  isDeleted      Boolean   @default(false) @map("is_deleted")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  branch            Branch              @relation(fields: [branchId], references: [id])
  priceItemPetShops PriceItemPetShop[]

  @@map("list_of_item_pet_shops")
}

model PriceItemPetShop {
  id                  BigInt    @id @default(autoincrement())
  listOfItemPetShopId BigInt    @map("list_of_item_pet_shop_id")
  sellingPrice        Decimal   @map("selling_price") @db.Decimal(15, 2)
  capitalPrice        Decimal   @map("capital_price") @db.Decimal(15, 2)
  petshopFee          Decimal   @default(0) @map("petshop_fee") @db.Decimal(15, 2)
  isDeleted           Boolean   @default(false) @map("is_deleted")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  listOfItemPetShop       ListOfItemPetShop        @relation(fields: [listOfItemPetShopId], references: [id])
  paymentPetshopItems     PaymentPetshopItem[]
  paymentClinicPetshopItems PaymentClinicPetshopItem[]
  masterPaymentPetshops   MasterPaymentPetshop[]

  @@map("price_item_pet_shops")
}

// ─── SERVICES ─────────────────────────────────────────────────────────────────

model ServiceCategory {
  id           BigInt    @id @default(autoincrement())
  categoryName String    @map("category_name")
  branchId     BigInt    @map("branch_id")
  isDeleted    Boolean   @default(false) @map("is_deleted")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  branch         Branch          @relation(fields: [branchId], references: [id])
  listOfServices ListOfService[]

  @@map("service_categories")
}

model ListOfService {
  id                BigInt    @id @default(autoincrement())
  serviceName       String    @map("service_name")
  description       String?
  durationMinutes   Int?      @map("duration_minutes")
  isActive          Boolean   @default(true) @map("is_active")
  serviceCategoryId BigInt    @map("service_category_id")
  branchId          BigInt    @map("branch_id")
  isDeleted         Boolean   @default(false) @map("is_deleted")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  serviceCategory     ServiceCategory      @relation(fields: [serviceCategoryId], references: [id])
  branch              Branch               @relation(fields: [branchId], references: [id])
  priceServices       PriceService[]

  @@map("list_of_services")
}

model PriceService {
  id              BigInt    @id @default(autoincrement())
  listOfServiceId BigInt    @map("list_of_service_id")
  sellingPrice    Decimal   @map("selling_price") @db.Decimal(15, 2)
  capitalPrice    Decimal   @map("capital_price") @db.Decimal(15, 2)
  doctorFee       Decimal   @default(0) @map("doctor_fee") @db.Decimal(15, 2)
  petshopFee      Decimal   @default(0) @map("petshop_fee") @db.Decimal(15, 2)
  isDeleted       Boolean   @default(false) @map("is_deleted")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  listOfService          ListOfService           @relation(fields: [listOfServiceId], references: [id])
  detailServicePatients  DetailServicePatient[]

  @@map("price_services")
}

// ─── MEDICINE GROUPS ──────────────────────────────────────────────────────────

model MedicineGroup {
  id          BigInt    @id @default(autoincrement())
  groupName   String    @map("group_name")
  description String?
  branchId    BigInt    @map("branch_id")
  isDeleted   Boolean   @default(false) @map("is_deleted")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  branch               Branch                    @relation(fields: [branchId], references: [id])
  priceMedicineGroups  PriceMedicineGroup[]
  detailMedicineGroups DetailMedicineGroupResult[]
  paymentMedicineGroups ListOfPaymentMedicineGroup[]

  @@map("medicine_groups")
}

model PriceMedicineGroup {
  id              BigInt    @id @default(autoincrement())
  medicineGroupId BigInt    @map("medicine_group_id")
  sellingPrice    Decimal   @map("selling_price") @db.Decimal(15, 2)
  capitalPrice    Decimal   @map("capital_price") @db.Decimal(15, 2)
  doctorFee       Decimal   @default(0) @map("doctor_fee") @db.Decimal(15, 2)
  petshopFee      Decimal   @default(0) @map("petshop_fee") @db.Decimal(15, 2)
  isDeleted       Boolean   @default(false) @map("is_deleted")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  medicineGroup MedicineGroup @relation(fields: [medicineGroupId], references: [id])

  @@map("price_medicine_groups")
}

// ─── CHECK-UP RESULTS ─────────────────────────────────────────────────────────

model CheckUpResult {
  id                       BigInt    @id @default(autoincrement())
  patientRegistrationId    BigInt    @unique @map("patient_registration_id")
  anamnesa                 String?
  sign                     String?
  diagnosa                 String?
  prognosis                String?
  homeInstructions         String?   @map("home_instructions")
  weightKg                 Decimal?  @map("weight_kg") @db.Decimal(6, 2)
  temperature              Decimal?  @db.Decimal(5, 2)
  heartRate                Int?      @map("heart_rate")
  respiratoryRate          Int?      @map("respiratory_rate")
  statusOutpatientInpatient Int      @default(0) @map("status_outpatient_inpatient")
  statusFinish             Boolean   @default(false) @map("status_finish")
  statusPaidOff            Boolean   @default(false) @map("status_paid_off")
  userId                   BigInt    @map("user_id")
  isDeleted                Boolean   @default(false) @map("is_deleted")
  deletedAt                DateTime? @map("deleted_at")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  registration         Registration              @relation(fields: [patientRegistrationId], references: [id])
  doctor               User                      @relation(fields: [userId], references: [id])
  images               CheckUpImage[]
  detailItems          DetailItemPatient[]
  detailServices       DetailServicePatient[]
  detailMedicineGroups DetailMedicineGroupResult[]
  payments             ListOfPayment[]
  weightRecord         WeightRecord?
  vaccinations         VaccinationRecord[]
  dewormings           DewormingRecord[]
  procedures           MajorProcedureRecord[]

  @@map("check_up_results")
}

model CheckUpImage {
  id              BigInt   @id @default(autoincrement())
  checkUpResultId BigInt   @map("check_up_result_id")
  imagePath       String   @map("image_path")
  filename        String
  createdAt       DateTime @default(now()) @map("created_at")

  checkUpResult CheckUpResult @relation(fields: [checkUpResultId], references: [id])

  @@map("check_up_images")
}

model DetailItemPatient {
  id             BigInt   @id @default(autoincrement())
  checkUpResultId BigInt  @map("check_up_result_id")
