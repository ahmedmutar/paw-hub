// ─── PAYROLL ──────────────────────────────────────────────────────────────────

model Payroll {
  id                  BigInt    @id @default(autoincrement())
  userEmployeeId      BigInt    @map("user_employee_id")
  branchId            BigInt    @map("branch_id")
  datePayed           DateTime  @map("date_payed")
  periodMonth         Int       @map("period_month")
  periodYear          Int       @map("period_year")
  basicSallary        Decimal   @map("basic_sallary") @db.Decimal(15, 2)
  accomodation        Decimal   @default(0) @db.Decimal(15, 2)
  percentageTurnover  Decimal   @default(0) @map("percentage_turnover") @db.Decimal(5, 2)
  amountTurnover      Decimal   @default(0) @map("amount_turnover") @db.Decimal(15, 2)
  totalTurnover       Decimal   @default(0) @map("total_turnover") @db.Decimal(15, 2)
  minusTurnover       Decimal   @default(0) @map("minus_turnover") @db.Decimal(15, 2)
  amountInpatient     Decimal   @default(0) @map("amount_inpatient") @db.Decimal(15, 2)
  countInpatient      Int       @default(0) @map("count_inpatient")
  totalInpatient      Decimal   @default(0) @map("total_inpatient") @db.Decimal(15, 2)
  percentageSurgery   Decimal   @default(0) @map("percentage_surgery") @db.Decimal(5, 2)
  amountSurgery       Decimal   @default(0) @map("amount_surgery") @db.Decimal(15, 2)
  totalSurgery        Decimal   @default(0) @map("total_surgery") @db.Decimal(15, 2)
  amountGrooming      Decimal   @default(0) @map("amount_grooming") @db.Decimal(15, 2)
  countGrooming       Int       @default(0) @map("count_grooming")
  totalGrooming       Decimal   @default(0) @map("total_grooming") @db.Decimal(15, 2)
  totalOverall        Decimal   @default(0) @map("total_overall") @db.Decimal(15, 2)
  pph21Amount         Decimal   @default(0) @map("pph21_amount") @db.Decimal(15, 2)
  userId              BigInt    @map("user_id")
  userUpdateId        BigInt?   @map("user_update_id")
  isDeleted           Boolean   @default(false) @map("is_deleted")
  deletedAt           DateTime? @map("deleted_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  employee  User @relation("EmployeePayrolls", fields: [userEmployeeId], references: [id])
  createdBy User @relation("CreatedByPayrolls", fields: [userId], references: [id])
  branch    Branch @relation(fields: [branchId], references: [id])

  @@unique([userEmployeeId, periodMonth, periodYear])
  @@map("payrolls")
}

// ─── EXPENSES ─────────────────────────────────────────────────────────────────

model Expense {
  id            BigInt    @id @default(autoincrement())
  dateSpend     DateTime  @map("date_spend")
  userIdSpender BigInt    @map("user_id_spender")
  branchId      BigInt    @map("branch_id")
  category      String    @default("Lain-lain")
  itemName      String    @map("item_name")
  notes         String?
  quantity      Decimal   @db.Decimal(10, 2)
  amount        Decimal   @db.Decimal(15, 2)
  amountOverall Decimal   @map("amount_overall") @db.Decimal(15, 2)
