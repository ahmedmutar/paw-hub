{
  "name": "vetclinic-api",
  "version": "2.0.0",
  "description": "PawCare Clinic API — Fastify + Prisma + PostgreSQL",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "postinstall": "prisma generate",
    "build": "tsc",
    "start": "node dist/app.js",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts && tsx prisma/seed-plans.ts",
    "db:reset": "prisma migrate reset --force && tsx prisma/seed.ts && tsx prisma/seed-plans.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:watch": "vitest --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@prisma/client": "^5.22.0",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.17.6",
    "bcryptjs": "^2.4.3",
    "exceljs": "^4.4.0",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "midtrans-client": "^1.4.3",
    "node-cron": "^4.5.0",
    "pdfkit": "^0.19.1",
    "pino-pretty": "^11.3.0",
    "qrcode": "^1.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/midtrans-client": "^1.4.0",
    "@types/node": "^22.7.5",
    "@types/qrcode": "^1.5.6",
    "@vitest/coverage-v8": "^4.1.9",
    "prisma": "^5.22.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.9"
  }
}
